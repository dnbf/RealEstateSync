@using RealEstateSync.Core.Models
@model RealEstateSync.Web.Models.HistoryViewModel

@{
    ViewData["Title"] = "Search History";
}

<h2 class="mb-4">Search History</h2>

@* Cards de resumo *@
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body text-center">
                <h6 class="card-title">Sessions</h6>
                <p class="card-text display-6 fw-bold">@Model.TotalSessions</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-secondary">
            <div class="card-body text-center">
                <h6 class="card-title">Total Items</h6>
                <p class="card-text display-6 fw-bold">@Model.TotalItems</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body text-center">
                <h6 class="card-title">Found</h6>
                <p class="card-text display-6 fw-bold">@Model.TotalFound</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger">
            <div class="card-body text-center">
                <h6 class="card-title">Errors</h6>
                <p class="card-text display-6 fw-bold">@Model.TotalErrors</p>
            </div>
        </div>
    </div>
</div>

@* Tabela de sessões *@
@if (Model.Entries == null || Model.Entries.Count == 0)
{
    <div class="alert alert-info">
        No search history found. Upload a CSV file on the Search screen to start.
    </div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>File Name</th>
                <th>Date</th>
                <th>Total Items</th>
                <th>Found</th>
                <th>Not Found</th>
                <th>Errors</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in Model.Entries)
            {
                <tr>
                    <td>@entry.Id</td>
                    <td><strong>@entry.FileName</strong></td>
                    <td>@entry.SearchDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-center">@entry.TotalItems</td>
                    <td class="text-center text-success fw-bold">@entry.FoundCount</td>
                    <td class="text-center text-warning fw-bold">@entry.NotFoundCount</td>
                    <td class="text-center text-danger fw-bold">@entry.ErrorCount</td>
                    <td>@(entry.Notes ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
}