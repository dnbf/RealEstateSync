@model RealEstateSync.Web.Models.SearchResultsViewModel

@{
    ViewData["Title"] = "Search Results";

    string GetStatusBadgeClass(RealEstateSync.Core.Models.RealEstateStatus status)
    {
        return status switch
        {
            RealEstateSync.Core.Models.RealEstateStatus.Found => "badge bg-success",
            RealEstateSync.Core.Models.RealEstateStatus.NotFound => "badge bg-warning text-dark",
            RealEstateSync.Core.Models.RealEstateStatus.Error => "badge bg-danger",
            _ => "badge bg-secondary"
        };
    }
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-3">
    <h2 class="mb-0">Search Results</h2>
    <a asp-controller="Search" asp-action="Index" class="btn btn-outline-primary btn-sm">
        &#8592; New Search
    </a>
</div>

<!-- Cards de resumo -->
<div class="row mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-white bg-primary mb-3 shadow-sm">
            <div class="card-body text-center">
                <h6 class="card-title">Total</h6>
                <p class="card-text display-6 fw-bold">@Model.TotalItems</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-white bg-success mb-3 shadow-sm">
            <div class="card-body text-center">
                <h6 class="card-title">Found</h6>
                <p class="card-text display-6 fw-bold">@Model.FoundItems</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-white bg-warning mb-3 shadow-sm">
            <div class="card-body text-center">
                <h6 class="card-title">Not Found</h6>
                <p class="card-text display-6 fw-bold">@Model.NotFoundItems</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-white bg-danger mb-3 shadow-sm">
            <div class="card-body text-center">
                <h6 class="card-title">Errors</h6>
                <p class="card-text display-6 fw-bold">@Model.ErrorItems</p>
            </div>
        </div>
    </div>
</div>

<!-- Tabela de resultados -->
@if (Model.Results == null || !Model.Results.Any())
{
    <div class="alert alert-info">No results found for this search.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Code</th>
                    <th>Portal</th>
                    <th>Status</th>
                    <th>Title</th>
                    <th>Price</th>
                    <th>Location</th>
                    <th>Link</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Results)
                {
                    <tr>
                        <td><strong>@r.Code</strong></td>
                        <td>@r.SearchPortal</td>
                        <td>
                            <span class="@GetStatusBadgeClass(r.Status)">
                                @r.Status
                            </span>
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(r.ListingTitle))
                            {
                                @r.ListingTitle
                            }
                            else if (!string.IsNullOrWhiteSpace(r.ErrorMessage))
                            {
                                <span class="text-danger small">@r.ErrorMessage</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(r.ListingPrice))
                            {
                                <span class="fw-bold text-success">@r.ListingPrice</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(r.ListingLocation))
                            {
                                @r.ListingLocation
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(r.ListingUrl) && r.ListingUrl != "#")
                            {
                                <a href="@r.ListingUrl" target="_blank" class="btn btn-outline-secondary btn-sm">
                                    View &#8599;
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-muted small">@r.SearchDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}